ths, all 5 PMs.\n2. Do not wait for December; calibrate to one score: 5 4 3 2 1.\n3. Compare with gut feel; when it corresponds, adopt it.\n4. Replace the current general review with it; own the\n    process, do not leave it to HR.","fontSize":20,"fontFamily":5,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"1. Run the scorecard retro for the past 3 months, all 5 PMs.\n2. Do not wait for December; calibrate to one score: 5 4 3 2 1.\n3. Compare with gut feel; when it corresponds, adopt it.\n4. Replace the current general review with it; own the\n    process, do not leave it to HR.","autoResize":true,"lineHeight":1.25}],"type":"excalidraw","version":2,"source":"https://excalidraw.com","appState":{"shouldCacheIgnoreZoom":false,"exportScale":2,"defaultSidebarDockedPreference":false,"openMenu":null,"showWelcomeScreen":true,"currentItemStrokeColor":"#1e1e1e","bindMode":"orbit","exportWithDarkMode":false,"lockedMultiSelections":{},"currentItemRoughness":1,"currentItemTextAlign":"left","exportBackground":true,"scrolledOutside":false,"selectedElementIds":{"ZuUbJp-avUsTRIqu_aJlj":true},"zenModeEnabled":false,"currentItemStartArrowhead":null,"zoom":{"value":0.741818},"theme":"light","activeTool":{"locked":false,"fromSelection":false,"lastActiveTool":null,"type":"selection","customType":null},"exportEmbedScene":false,"gridStep":5,"lastPointerDownWith":"mouse","selectedGroupIds":{},"currentItemBackgroundColor":"transparent","scrollY":105.8961567720814,"penDetected":false,"viewBackgroundColor":"#ffffff","isBindingEnabled":true,"currentItemFontFamily":5,"isMidpointSnappingEnabled":true,"currentItemArrowType":"round","name":"Untitled-2026-07-20-1458","currentItemOpacity":100,"preferredSelectionTool":{"type":"selection","initialized":true},"scrollX":-1535.8563026979066,"stats":{"panels":3,"open":false},"objectsSnapModeEnabled":false,"gridSize":20,"gridModeEnabled":false,"openSidebar":null,"bindingPreference":"enabled","currentItemRoundness":"round","curre