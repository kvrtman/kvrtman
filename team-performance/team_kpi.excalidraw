,"strokeStyle":"solid","id":"Li4JxnXKz7W7jt9NJ_AOc","strokeWidth":4,"roughness":1,"isDeleted":false,"fontSize":20,"opacity":100,"verticalAlign":"top","updated":1784542807238,"locked":false,"text":"Weekly - tracker: due vs delivered, resyncs\nMonthly - numbers readout (context, not scoring)\nQuarterly - scorecard vs the bar \u2192 one score","version":51,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b0f","roundness":null,"containerId":null,"originalText":"Weekly - tracker: due vs delivered, resyncs\nMonthly - numbers readout (context, not scoring)\nQuarterly - scorecard vs the bar \u2192 one score","height":75,"link":null,"strokeColor":"#1e1e1e","fillStyle":"solid","groupIds":[],"versionNonce":1638180539,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":null,"x":4228.290147915198,"angle":0,"y":6.405695004745326,"width":484.8},{"id":"N8ZUGCR2O7ZPoIp0UAR3O","type":"text","x":1995,"y":692,"width":757.5,"height":25.0,"angle":0,"strokeColor":"#203AA9","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":1,"opacity":100,"groupIds":[],"frameId":null,"index":"b0g","roundness":null,"seed":913776401,"version":1,"versionNonce":1098501434,"isDeleted":false,"boundElements":[],"updated":1784542807238,"link":null,"locked":false,"text":"Tier 3 = what we are doing to fix and balance \u2192 it becomes the project list","fontSize":20,"fontFamily":5,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"Tier 3 = what we are doing to fix and balance \u2192 it becomes the project list","autoResize":true,"lineHeight":1.25},{"id":"RlN5PRM55NoEAi2bRJOxI","type":"text","x":3055,"y":168,"width":272.7,"height":25.0,"angle":0,"strokeColor":"#203AA9","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":1,"opacity":100,"groupIds":[],"frameId":null,"index":"b0h","roundness":null,"seed":1428072476,"version":1,"versionNonce":1520751762,"isDeleted":false,"boundElements":[],"updated":1784542807238,"link":null,"locked":false,"text":"Who owns the numbers (Ivan)","fontSize":20,"fontFamily":5,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"Who owns the numbers (Ivan)","autoResize":true,"lineHeight":1.25},{"id":"DlIn6ZeS0p4bOKOcqPC-z","type":"text","x":3055,"y":208,"width":666.6,"height":50.0,"angle":0,"strokeColor":"#1e1e1e","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":1,"opacity":100,"groupIds":[],"frameId":null,"index":"b0i","roundness":null,"seed":1387404152,"version":1,"versionNonce":2010886661,"isDeleted":false,"boundElements":[],"updated":1784542807238,"link":null,"locked":false,"text":"Volume and PBT are management-owned: Ivan + Kurt + top mgmt define\nthe numbers and choose the actions and projects to get there.","fontSize":20,"fontFamily":5,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"Volume and PBT are management-owned: Ivan + Kurt + top mgmt define\nthe numbers and choose the actions and projects to get there.","autoResize":true,"lineHeight":1.25},{"id":"_jbjj8bfHoeLZEynah8Ar","type":"text","x":3055,"y":278,"width":626.2,"height":25.0,"angle":0,"strokeColor":"#1e1e1e","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":1,"opacity":100,"groupIds":[],"frameId":null,"index":"b0j","roundness":null,"seed":550708610,"version":1,"versionNonce":851390641,"isDeleted":false,"boundElements":[],"updated":1784542807238,"link":null,"locked":false,"text":"Do not punish the team for the number: they are not magicians.","fontSize":20,"fontFamily":5,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"Do not punish the team for the number: they are not magicians.","autoResize":true,"lineHeight":1.25},{"id":"QEhiocURGy5-hiqLykIm8","type":"text","x":3055,"y":323,"width":707.0,"height":50.0,"angle":0,"strokeColor":"#1e1e1e","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":1,"opacity":100,"groupIds":[],"frameId":null,"index":"b0k","roundness":null,"seed":1300183755,"version":1,"versionNonce":2031230106,"isDeleted":false,"boundElements":[],"updated":1784542807238,"link":null,"locked":false,"text":"Volume-as-KPI is the network team's mood setter. Product is not sales:\nour end goal is profit, and sometimes less sales means more profit.","fontSize":20,"fontFamily":5,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"Volume-as-KPI is the network team's mood setter. Product is not sales:\nour end goal is profit, and sometimes less sales means more profit.","autoResize":true,"lineHeight":1.25},{"id":"vpGn_RkYezvyz0OU1OwtT","type":"text","x":3055,"y":393,"width":606.0,"height":25.0,"angle":0,"strokeColor":"#1e1e1e","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":1,"opacity":100,"groupIds":[],"frameId":null,"index":"b0l","roundness":null,"seed":704636181,"version":1,"versionNonce":751715256,"isDeleted":false,"boundElements":[],"updated":1784542807238,"link":null,"locked":false,"text":"The team's real impact = delivery of the projects we agreed.","fontSize":20,"fontFamily":5,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"The team's real impact = delivery of the projects we agreed.","autoResize":true,"lineHeight":1.25},{"id":"Oy4wZNd9y_BPYfstjEa6k","type":"text","x":4090,"y":150,"width":343.4,"height":25.0,"angle":0,"strokeColor":"#203AA9","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":1,"opacity":100,"groupIds":[],"frameId":null,"index":"b0m","roundness":null,"seed":1399872264,"version":1,"versionNonce":1579344624,"isDeleted":false,"boundElements":[],"updated":1784542807238,"link":null,"locked":false,"text":"Score the DELIVERY, not the number","fontSize":20,"fontFamily":5,"t